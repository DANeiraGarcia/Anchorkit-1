{
  "name": "@anchorkit/dev-panel",
  "version": "0.1.0",
  "description": "Developer panel for debugging SEP-6/SEP-10 anchor requests",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./panel": {
      "import": "./dist/components/AnchorRequestPanel.js",
      "types": "./dist/components/AnchorRequestPanel.d.ts"
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build": "tsc --build",
    "build:storybook": "storybook build",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@storybook/react": "^7.6.7",
    "@storybook/addon-essentials": "^7.6.7",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.1.0"
  }
}
